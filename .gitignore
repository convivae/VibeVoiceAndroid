flutter_app/android/local.properties

# iOS (Flutter creates this on iOS builds)
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/Flutter.framework
flutter_app/ios/Flutter/Flutter.podspec
flutter_app/ios/Flutter/app.flx
flutter_app/ios/Flutter/app.zip
flutter_app/ios/Flutter/flutter_assets/
flutter_app/ios/Flutter/engine artifacts

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg
.env
.venv/
venv/
cloud_server/__pycache__/
cloud_server/app/__pycache__/
cloud_server/app/**/__pycache__/
cloud_server/.env
cloud_server/venv/
cloud_server/venv/

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

